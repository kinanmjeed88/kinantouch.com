den;\n      box-shadow: \n        0 10px 40px rgba(0, 0, 0, 0.5),\n        0 0 0 1px rgba(63, 169, 255, 0.2);\n      transition: transform 0.3s ease, box-shadow 0.3s ease;\n    }\n\n    .video-wrapper:hover {\n      transform: translateY(-2px);\n      box-shadow: \n        0 15px 50px rgba(0, 0, 0, 0.6),\n        0 0 0 1px rgba(63, 169, 255, 0.4);\n    }\n\n    .video-wrapper iframe {\n      position: absolute;\n      top: 0;\n      left: 0;\n      width: 100%;\n      height: 100%;\n      border: none;\n    }\n\n    /* العنوان */\n    h1 {\n      font-size: clamp(20px, 5vw, 28px);\n      font-weight: 900;\n      line-height: 1.5;\n      margin-bottom: 18px;\n      background: linear-gradient(135deg, #ffffff 0%, #b8d4ff 100%);\n      -webkit-background-clip: text;\n      -webkit-text-fill-color: transparent;\n      background-clip: text;\n      text-align: center;\n      letter-spacing: -0.5px;\n    }\n\n    /* الفقرات */\n    p {\n      font-size: clamp(15px, 3.5vw, 17px);\n      line-height: 1.9;\n      margin-bottom: 16px;\n      color: #d4deff;\n      text-align: justify;\n    }\n\n    /* المميزات */\n    .features {\n      margin: 25px 0;\n      display: flex;\n      flex-direction: column;\n      gap: 12px;\n    }\n\n    .feature {\n      background: linear-gradient(135deg, rgba(63, 169, 255, 0.12), rgba(63, 169, 255, 0.04));\n      border-right: 3px solid #3fa9ff;\n      padding: 14px 12px;\n      border-radius: 12px;\n      font-size: clamp(14px, 3.2vw, 16px);\n      line-height: 1.8;\n      color: #e8f2ff;\n      transition: all 0.3s ease;\n      backdrop-filter: blur(10px);\n    }\n\n    .feature:hover {\n      background: linear-gradient(135deg, rgba(63, 169, 255, 0.18), rgba(63, 169, 255, 0.08));\n      transform: translateX(-3px);\n      box-shadow: 0 4px 15px rgba(63, 169, 255, 0.2);\n    }\n\n    /* الهاشتاقات */\n    .tags {\n      margin-top: 30px;\n      padding-top: 20px;\n      border-top: 1px solid rgba(255, 255, 255, 0.08);\n      text-align: center;\n      display: flex;\n      flex-wrap: wrap;\n      gap: 8px;\n      justify-content: center;\n    }\n\n    .tag {\n      display: inline-block;\n      background: rgba(255, 215, 0, 0.1);\n      color: #ffd700;\n      padding: 6px 12px;\n      border-radius: 20px;\n      font-size: clamp(12px, 2.8vw, 14px);\n      font-weight: 600;\n      border: 1px solid rgba(255, 215, 0, 0.2);\n      transition: all 0.3s ease;\n    }\n\n    .tag:hover {\n      background: rgba(255, 215, 0, 0.2);\n      transform: translateY(-2px);\n    }\n\n    /* القسم الرسمي */\n    .official {\n      margin-top: 35px;\n      padding: 25px 18px;\n      border-radius: 16px;\n      background: linear-gradient(135deg, rgba(63, 169, 255, 0.08), rgba(63, 169, 255, 0.02));\n      border: 1px solid rgba(63, 169, 255, 0.2);\n      text-align: center;\n      backdrop-filter: blur(10px);\n    }\n\n    .official-title {\n      font-size: clamp(15px, 3.5vw, 17px);\n      margin-bottom: 15px;\n      color: #ffffff;\n      font-weight: 600;\n    }\n\n    .official a {\n      display: inline-block;\n      text-decoration: none;\n      background: linear-gradient(135deg, #3fa9ff 0%, #2d8be0 100%);\n      color: #fff;\n      padding: 14px 35px;\n      border-radius: 12px;\n      font-weight: 700;\n      font-size: clamp(14px, 3.2vw, 16px);\n      transition: all 0.3s ease;\n      box-shadow: 0 5px 20px rgba(63, 169, 255, 0.3);\n      position: relative;\n      overflow: hidden;\n    }\n\n    .official a::before {\n      content: \"\";\n      position: absolute;\n      top: 0;\n      left: -100%;\n      width: 100%;\n      height: 100%;\n      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);\n      transition: left 0.5s ease;\n    }\n\n    .official a:hover::before {\n      left: 100%;\n    }\n\n    .official a:hover {\n      background: linear-gradient(135deg, #2d8be0 0%, #1a6fb8 100%);\n      transform: translateY(-2px);\n      box-shadow: 0 8px 30px rgba(63, 169, 