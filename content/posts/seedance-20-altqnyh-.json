uto;\n  max-width:950px;\n}\n\n.seedance-feature{\n  background:rgba(255,255,255,0.03);\n  padding:26px;\n  border-radius:18px;\n  font-size:20px;\n  line-height:2.2;\n  color:#e8e8e8;\n  transition:.3s ease;\n}\n\n.seedance-feature:hover{\n  background:rgba(255,255,255,0.06);\n  transform:translateX(-6px);\n}\n\n/* مربع التأكيد */\n.seedance-highlight{\n  background:rgba(255,255,255,0.04);\n  border-radius:24px;\n  padding:40px;\n  margin:70px auto;\n  text-align:center;\n  color:#ffffff;\n  font-weight:700;\n  font-size:22px;\n  line-height:2.3;\n  max-width:950px;\n}\n\n/* الوسوم */\n.seedance-tags{\n  display:flex;\n  flex-wrap:wrap;\n  gap:18px;\n  justify-content:center;\n  margin:70px 0 50px;\n}\n\n.seedance-tag{\n  background:rgba(255,255,255,0.04);\n  color:#bfbfbf;\n  padding:14px 26px;\n  border-radius:30px;\n  font-size:17px;\n}\n\n/* ===== CTA ===== */\n.seedance-cta{\n  margin-top:80px;\n  padding:60px 20px;\n  text-align:center;\n  border-top:1px solid rgba(255,255,255,0.05);\n}\n\n.seedance-cta-title{\n  font-size:26px;\n  margin-bottom:25px;\n  font-weight:900;\n  color:#ffffff;\n}\n\n/* زر صغير أنيق */\n.seedance-cta a{\n  display:inline-block;\n  background:transparent;\n  color:#ffffff;\n  text-decoration:none;\n  padding:8px 22px;\n  border-radius:8px;\n  font-weight:600;\n  font-size:15px;\n  border:1px solid rgba(255,255,255,0.15);\n  transition:.3s ease;\n}\n\n.seedance-cta a:hover{\n  background:rgba(255,255,255,0.08);\n  border-color:rgba(255,255,255,0.3);\n}\n\n/* موبايل */\n@media(max-width:480px){\n  .seedance-card{padding:50px 25px;}\n  .seedance-feature{font-size:17px;}\n  .seedance-highlight{font-size:18px;}\n}\n</style>\n\n<div class=\"seedance-card\" id=\"seedanceCard\">\n\n<div class=\"seedance-video-wrapper\">\n  <iframe \n    src=\"https://www.youtube.com/embed/9eUJYOjVmYs\"\n    allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\"\n    allowfullscreen\n    loading=\"lazy\">\n  </iframe>\n</div>\n\n<h1 class=\"seedance-title\">🎬 هوليوود في مأزق حقيقي 🤯</h1>\n\n<p class=\"seedance-text\">\nهذا هو Seedance 2.0… النموذج الذي لا يكتفي بتجاوز الوادي الغريب، بل يمحوه تمامًا.\n</p>\n\n<p class=\"seedance-text\">\nالواقعية هنا صادمة إلى حد يصعب تجاهله:\n</p>\n\n<h3 class=\"seedance-section-title\">المميزات الرئيسية</h3>\n\n<div class=\"seedance-features\">\n  <div class=\"seedance-feature\">🔹 تعبيرات دقيقة جدًا (Micro-expressions) تشبه الإنسان الحقيقي</div>\n  <div class=\"seedance-feature\">🔹 إحساس بالوزن والحركة يجعل الجسد يبدو طبيعيًا لا مصطنعًا</div>\n  <div class=\"seedance-feature\">🔹 حوارات نابضة بالحياة تشعرك أنك أمام ممثل حقيقي، لا نموذج مولَّد</div>\n</div>\n\n<div class=\"seedance-highlight\">\nلم يعد هناك ما يصرخ: هذا ذكاء اصطناعي.<br>\nالحد الفاصل بين الحقيقي والمولَّد بدأ يختفي بسرعة مخيفة.\n</div>\n\n<h3 class=\"seedance-section-title\">التأثير على صناعة السينما</h3>\n\n<p class=\"seedance-text\">\nالسؤال الآن ليس: هل سيؤثر الذكاء الاصطناعي على صناعة السينما؟<br>\nبل: كيف ستعيد هوليوود تعريف نفسها بعد هذا المستوى؟\n</p>\n\n<div class=\"seedance-tags\">\n  <span class=\"seedance-tag\">#الذكاء_الاصطناعي</span>\n  <span class=\"seedance-tag\">#Seedance</span>\n  <span class=\"seedance-tag\">#توليد_الفيديو</span>\n  <span class=\"seedance-tag\">#صناعة_السينما</span>\n  <span class=\"seedance-tag\">#Hollywood</span>\n</div>\n\n<div class=\"seedance-cta\">\n  <div class=\"seedance-cta-title\">الموقع الرسمي لـ Seedance</div>\n  <a href=\"https://seedance2.ai/\" target=\"_blank\">اضغط هنا</a>\n</div>\n\n</div>\n\n<script>\nconst observer = new IntersectionObserver(entries=>{\n  entries.forEach(entry=>{\n    if(entry.isIntersecting){\n      entry.target.classList.add('visible');\n    }\n  });\n},{threshold:0.2});\nobserver.observe(document.getElementById('seedanceCard'));\n</script>\n\n</section>",
