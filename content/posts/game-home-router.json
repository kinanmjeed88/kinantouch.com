  "content": "<!DOCTYPE html>\n<html lang=\"ar\" dir=\"rtl\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>دليل شراء الراوترات - العراق 2026</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\">\n    <style>\n        :root {\n            --bg: #0a0e1a;\n            --surface: #111827;\n            --surface2: #1a2235;\n            --border: #1e2d45;\n            --border-bright: #2d4a6e;\n            --accent: #0ea5e9;\n            --accent-dim: #0c2a3e;\n            --accent-glow: rgba(14,165,233,0.15);\n            --gold: #f59e0b;\n            --gold-dim: #2d1f06;\n            --green: #10b981;\n            --green-dim: #062016;\n            --red: #ef4444;\n            --text-primary: #f1f5f9;\n            --text-secondary: #94a3b8;\n            --text-muted: #475569;\n        }\n\n        * { margin: 0; padding: 0; box-sizing: border-box; }\n\n        body {\n            font-family: 'IBM Plex Sans Arabic', sans-serif;\n            background: var(--bg);\n            color: var(--text-primary);\n            min-height: 100vh;\n            overflow-x: hidden;\n            line-height: 1.5;\n        }\n\n        /* ─── HEADER ─── */\n        .header {\n            background: linear-gradient(135deg, #0a0e1a 0%, #0d1829 50%, #0a1220 100%);\n            border-bottom: 1px solid var(--border);\n            padding: 30px 20px;\n            position: relative;\n        }\n\n        .header-inner {\n            max-width: 1300px;\n            margin: 0 auto;\n            display: flex;\n            align-items: center;\n            justify-content: space-between;\n            gap: 20px;\n        }\n\n        .header-eyebrow {\n            font-size: 11px;\n            font-weight: 600;\n            letter-spacing: 2px;\n            text-transform: uppercase;\n            color: var(--accent);\n            margin-bottom: 8px;\n        }\n\n        .header-title {\n            font-size: 24px;\n            font-weight: 700;\n            color: var(--text-primary);\n            line-height: 1.2;\n        }\n\n        .header-title span { color: var(--accent); }\n\n        .header-meta { display: flex; gap: 15px; flex-shrink: 0; }\n\n        .meta-pill {\n            background: var(--surface2);\n            border: 1px solid var(--border);\n            border-radius: 8px;\n            padding: 10px 16px;\n            text-align: center;\n            min-width: 70px;\n        }\n\n        .meta-pill .val {\n            font-size: 20px;\n            font-weight: 700;\n            color: var(--accent);\n            display: block;\n            line-height: 1;\n        }\n\n        .meta-pill .lbl {\n            font-size: 11px;\n            color: var(--text-muted);\n            margin-top: 4px;\n            display: block;\n        }\n\n        /* ─── MAIN ─── */\n        .main {\n            max-width: 1300px;\n            margin: 0 auto;\n            padding: 20px;\n        }\n\n        /* ─── RESPONSIVE GRID TABLE (MOBILE FIRST) ─── */\n        .rtable-container {\n            margin-bottom: 20px;\n            animation: fadeIn 0.3s ease both;\n        }\n\n        /* Desktop Header (hidden on mobile) */\n        .rtable-header {\n            display: none;\n            background: var(--surface2);\n            border-radius: 8px 8px 0 0;\n            border: 1px solid var(--border);\n            border-bottom: 2px solid var(--border-bright);\n            grid-template-columns: 1.5fr 1.2fr repeat(5, 1fr) 100px;\n            gap: 10px;\n            padding: 12px 15px;\n        }\n\n        .rtable-header div {\n            font-size: 11px;\n            font-weight: 600;\n            color: var(--text-muted);\n            text-transform: uppercase;\n            letter-spacing: 0.5px;\n        }\n\n        /* Rows Container */\n        .rtable-body {\n            display: flex;\n            flex-direction: column;\n            gap: 15px;\n        }\n\n        /* Individual Row / Card on Mobile */\n        .rtable-row {\n            background: var(--surface);\n            border: 1px solid var(--border);\n            border-radius: 10px;\n            padding: 15px;\n            display: flex;\n            flex-direction: column;\n            gap: 10px;\n            transition: transform 0.2s ease, border-color 0.2s ease;\n        }\n\n        .rtable-row:hover {\n            border-color: var(--border-bright);\n            transform: translateY(-2px);\n        }\n\n        /* Cell styling on Mobile */\n        .rtable-row > div {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            font-size: 13px;\n            color: var(--text-secondary);\n            padding-bottom: 8px;\n            border-bottom: 1px solid rgba(30, 45, 69, 0.5);\n        }\n\n        .rtable-row > div:last-child {\n            border-bottom: none;\n            padding-bottom: 0;\n            margin-top: 5px;\n        }\n\n        /* Mobile Label */\n        .rtable-row > div::before {\n            content: attr(data-label);\n            font-size: 11px;\n            font-weight: 500;\n            color: var(--text-muted);\n            padding-left: 10px;\n        }\n\n        /* Specific Cell Overrides on Mobile */\n        .rtable-row .r-model-cell {\n            flex-direction: column;\n            align-items: flex-start;\n            border-bottom: 2px solid var(--border);\n            padding-bottom: 10px;\n            margin-bottom: 5px;\n        }\n\n        .rtable-row .r-model-cell::before { display: none; }\n\n        .rtable-row .r-price-cell {\n            background: var(--surface2);\n            padding: 10px;\n            border-radius: 6px;\n            border-bottom: none;\n        }\n\n        /* ─── IMAGE STYLING ─── */\n        .router-img-box {\n            width: 100px;\n            height: 70px;\n            background: #fff;\n            padding: 5px;\n            border-radius: 6px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            margin: 10px 0;\n        }\n        .router-img-box img {\n            max-width: 100%;\n            max-height: 100%;\n            object-fit: contain;\n        }\n\n        /* ─── DATA STYLING INNER ELEMENTS ─── */\n        .brand-badge {\n            display: inline-block;\n            padding: 2px 8px;\n            border-radius: 4px;\n            font-size: 9px;\n            font-weight: 700;\n            text-transform: uppercase;\n            margin-bottom: 5px;\n        }\n        .brand-tplink  { background: #1a3a5c; color: #60a5fa; }\n        .brand-ruijie  { background: #3a1a1a; color: #f87171; }\n        .brand-huawei  { background: #1a3a1a; color: #4ade80; }\n        .brand-xiaomi  { background: #3a1a3a; color: #e879f9; }\n        .brand-asus    { background: #2a2a1a; color: #facc15; }\n\n        .device-name {\n            font-size: 15px;\n            font-weight: 700;\n            color: var(--text-primary);\n        }\n\n        .price-val {\n            font-size: 16px;\n            font-weight: 700;\n            color: var(--gold);\n        }\n\n        .rate {\n            font-weight: 600;\n            padding: 1px 6px;\n            border-radius: 3px;\n            font-size: 12px;\n        }\n        .rate-ex  { background: #062016; color: #4ade80; }\n        .rate-vg  { background: #0c2a3e; color: #38bdf8; }\n        .rate-gd  { background: #1a1a06; color: #a3e635; }\n\n        /* الأزرق = الأفضل */\n        .b-cool { color: var(--accent) !important; font-weight: 600; }\n        /* الأحمر = الأضعف */\n        .b-warm { color: #f87171 !important; font-weight: 600; }\n\n        /* ─── DESKTOP MEDIA QUERY (min-width: 950px) ─── */\n        @media (min-width: 950px) {\n            .rtable-header { display: grid; }\n            \n            .rtable-body { gap: 0; border: 1px solid var(--border); border-top: none; border-radius: 0 0 8px 8px; background: var(--surface); }\n\n            .rtable-row {\n                display: grid;\n                grid-template-columns: 1.5fr 1.2fr repeat(5, 1fr) 100px;\n                gap: 10px;\n                padding: 12px 15px;\n                border: none;\n                border-bottom: 1px solid var(--border);\n                border-radius: 0;\n                flex-direction: row;\n                align-items: center;\n            }\n            .rtable-row:last-child { border-bottom: none; border-radius: 0 0 8px 8px; }\n\n            .rtable-row > div {\n                display: block;\n                border: none;\n                padding: 0;\n                margin: 0;\n                font-size: 12.5px;\n            }\n            .rtable-row > div::before { display: none; }\n\n            .rtable-row .r-model-cell { flex-direction: row; align-items: center; border: none; padding: 0; margin: 0; gap: 12px; }\n            .rtable-row .r-price-cell { background: transparent; padding: 0; }\n\n            .router-img-box { width: 50px; height: 40px; margin: 0; flex-shrink: 0; }\n            .device-name { font-size: 13px; }\n            .price-val { font-size: 14px; text-align: left; display: block;}\n        }\n\n        /* ─── DIVIDER ─── */\n        .section-divider {\n            display: flex;\n            align-items: center;\n            gap: 15px;\n            margin: 25px 0 15px;\n        }\n        .section-divider span {\n            font-size: 11px;\n            font-weight: 700;\n            letter-spacing: 2px;\n            text-transform: uppercase;\n            color: var(--text-muted);\n            white-space: nowrap;\n        }\n        .section-divider::before, .section-divider::after {\n            content: '';\n            flex: 1;\n            height: 1px;\n            background: var(--border);\n        }\n\n        /* ─── UNIQUE FEATURES SECTION ─── */\n        .features-section {\n            background: var(--surface);\n            border: 1px solid var(--border);\n            border-radius: 10px;\n            overflow: hidden;\n            margin-bottom: 15px;\n            animation: fadeIn 0.3s 0.1s ease both;\n        }\n\n        .features-grid {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));\n        }\n\n        .feature-item {\n            padding: 15px;\n            border-bottom: 1px solid var(--border);\n            border-left: 1px solid var(--border);\n            transition: background 0.2s;\n        }\n        .feature-item:hover { background: rgba(14,165,233,0.03); }\n\n        @media (min-width: 600px) {\n            .feature-item:nth-child(2n) { border-left: none; }\n        }\n        @media (min-width: 900px) {\n            .feature-item:nth-child(2n) { border-left: 1px solid var(--border); }\n            .feature-item:nth-child(3n) { border-left: none; }\n        }\n\n        .feature-header {\n            display: flex;\n            align-items: center;\n            gap: 8px;\n            margin-bottom: 8px;\n        }\n\n        .feature-brand {\n            font-size: 9px;\n            font-weight: 700;\n            text-transform: uppercase;\n            padding: 1px 6px;\n            border-radius: 3px;\n        }\n\n        .feature-model {\n            font-size: 13px;\n            font-weight: 700;\n            color: var(--text-primary);\n        }\n\n        .feature-badge {\n            display: inline-flex;\n            align-items: center;\n            gap: 6px;\n            background: var(--surface2);\n            border: 1px solid var(--border-bright);\n            border-radius: 5px;\n            padding: 5px 10px;\n            margin-bottom: 8px;\n        }\n\n        .badge-icon { font-size: 14px; }\n        .badge-text {\n            font-size: 11px;\n            font-weight: 700;\n            color: var(--accent);\n        }\n\n        .feature-desc {\n            font-size: 11px;\n            color: var(--text-muted);\n            line-height: 1.6;\n        }\n\n        /* ─── BOTTOM GRID ─── */\n        .bottom-grid {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n            gap: 15px;\n            animation: fadeIn 0.3s 0.2s ease both;\n        }\n\n        .info-card, .winner-card {\n            background: var(--surface);\n            border: 1px solid var(--border);\n            border-radius: 10px;\n            overflow: hidden;\n        }\n\n        .card-header {\n            background: var(--surface2);\n            padding: 12px 16px;\n            border-bottom: 1px solid var(--border);\n            display: flex;\n            align-items: center;\n            gap: 10px;\n        }\n\n        .card-header .dot {\n            width: 7px; height: 7px;\n            border-radius: 50%;\n            background: var(--accent);\n        }\n\n        .card-header h3 {\n            font-size: 13px;\n            font-weight: 600;\n            color: var(--text-secondary);\n        }\n\n        .card-body {\n            padding: 16px;\n            display: flex;\n            flex-direction: column;\n            gap: 12px;\n        }\n\n        .note-item, .winner-item {\n            display: flex;\n            gap: 12px;\n            align-items: flex-start;\n        }\n\n        .note-icon, .winner-rank {\n            width: 30px; height: 30px;\n            border-radius: 6px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 14px;\n            flex-shrink: 0;\n            margin-top: 2px;\n        }\n\n        .note-text strong {\n            display: block;\n            font-size: 12px;\n            font-weight: 600;\n            color: var(--text-primary);\n            margin-bottom: 2px;\n        }\n\n        .note-text p, .winner-reason {\n            font-size: 11px;\n            color: var(--text-muted);\n            line-height: 1.6;\n        }\n\n        /* ─── WINNER CARD ─── */\n        .winner-item {\n            padding: 16px;\n            border-bottom: 1px solid var(--border);\n        }\n        .winner-item:last-child { border-bottom: none; }\n\n        .winner-rank { font-size: 16px; width: 35px; height: 35px;}\n        .rank-gold { background: var(--gold-dim); }\n        .rank-silver { background: #1a1a2a; }\n\n        .winner-label {\n            font-size: 10px;\n            font-weight: 600;\n            color: var(--text-muted);\n            text-transform: uppercase;\n            margin-bottom: 4px;\n        }\n\n        .winner-name {\n            font-size: 16px;\n            font-weight: 700;\n            margin-bottom: 5px;\n        }\n        .winner-name.gold { color: var(--gold); }\n        .winner-name.silver { color: #94a3b8; }\n\n        .winner-tags {\n            display: flex;\n            gap: 6px;\n            flex-wrap: wrap;\n            margin-top: 8px;\n        }\n\n        .tag {\n            padding: 3px 8px;\n            border-radius: 4px;\n            font-size: 10px;\n            font-weight: 600;\n            background: var(--surface2);\n            color: var(--text-muted);\n            border: 1px solid var(--border);\n        }\n\n        /* ─── FOOTER ─── */\n        .footer {\n            border-top: 1px solid var(--border);\n            padding: 15px 20px;\n            max-width: 1300px;\n            margin: 10px auto 0;\n            display: flex;\n            align-items: center;\n            justify-content: space-between;\n            gap: 10px;\n            flex-wrap: wrap;\n        }\n\n        .footer p { font-size: 11px; color: var(--text-muted); }\n\n        .footer .update-badge {\n            background: var(--surface2);\n            border: 1px solid var(--border);\n            border-radius: 5px;\n            padding: 4px 12px;\n            font-size: 11px;\n            color: var(--accent);\n            font-weight: 500;\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; transform: translateY(8px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n\n    </style>\n</head>\n<body>\n\n<div class=\"header\">\n    <div class=\"header-inner\">\n        <div>\n            <div class=\"header-eyebrow\">دليل شراء 2026 — السوق العراقي</div>\n            <h1 class=\"header-title\">مقارنة الراوترات <span>85-100 الف دينار</span></h1>\n        </div>\n        <div class=\"header-meta\">\n            <div class=\"meta-pill\">\n                <span class=\"val\">9</span>\n                <span class=\"lbl\">موديلات</span>\n            </div>\n            <div class=\"meta-pill\">\n                <span class=\"val\">5</span>\n                <span class=\"lbl\">شركات</span>\n            </div>\n        </div>\n    </div>\n</div>\n\n<div class=\"main\">\n\n    <div class=\"rtable-container\">\n        <div class=\"rtable-header\">\n            <div>الموديل</div>\n            <div>المعالج</div>\n            <div>اختراق الجدران</div>\n            <div>الاستقرار</div>\n            <div>الألعاب</div>\n            <div>السرعة</div>\n            <div>السعر (د.ع)</div>\n        </div>\n\n        <div class=\"rtable-body\">\n            <div class=\"rtable-row\">\n                <div class=\"r-model-cell\">\n                    <div class=\"router-img-box\"><img src=\"https://static.tp-link.com/Archer-AX55-01_1626343542525v.jpg\" alt=\"AX55\"></div>\n                    <div>\n                        <span class=\"brand-badge brand-tplink\">TP-Link</span>\n                        <span class=\"device-name\">Archer AX55</span>\n                    </div>\n                </div>\n                <div data-label=\"المعالج\">Qualcomm ثنائي</div>\n                <div data-label=\"اختراق الجدران\" class=\"b-warm\">متوسط (4 هوائيات)</div>\n                <div data-label=\"مقاومة التشويش\"><span class=\"rate rate-ex\">ممتاز</span></div>\n                <div data-label=\"استقرار الألعاب\"><span class=\"rate rate-ex\">ممتاز</span></div>\n                <div data-label=\"السرعة الإجمالية\">3000 Mbps</div>\n                <div data-label=\"السعر\" class=\"r-price-cell\"><span class=\"price-val\">85,000</span></div>\n            </div>\n\n            <div class=\"rtable-row\">\n                <div class=\"r-model-cell\">\n                    <div class=\"router-img-box\"><img src=\"https://static.tp-link.com/Archer-AX53-01_1635817812547d.jpg\" alt=\"AX53\"></div>\n                    <div>\n                        <span class=\"brand-badge brand-tplink\">TP-Link</span>\n                        <span class=\"device-name\">Archer AX53</span>\n                    </div>\n                </div>\n                <div data-label=\"المعالج\" class=\"b-warm\">1.0GHz (بطيء)</div>\n                <div data-label=\"اختراق الجدران\">جيدة</div>\n                <div data-label=\"مقاومة التشويش\"><span class=\"rate rate-vg\">جيد جداً</span></div>\n                <div data-label=\"استقرار الألعاب\"><span class=\"rate rate-ex\">ممتاز</span></div>\n                <div data-label=\"السرعة الإجمالية\">3000 Mbps</div>\n                <div data-label=\"السعر\" class=\"r-price-cell\"><span class=\"price-val b-cool\">75,000</span></div>\n            </div>\n\n            <div class=\"rtable-row\">\n                <div class=\"r-model-cell\">\n                    <div class=\"router-img-box\"><img src=\"https://static.ruijienetworks.com/20230614/668270387532390400.png\" alt=\"EW3000GX\"></div>\n                    <div>\n                        <span class=\"brand-badge brand-ruijie\">Ruijie</span>\n                        <span class=\"device-name\">EW3000GX PRO</span>\n                    </div>\n                </div>\n                <div data-label=\"المعالج\">معمارية شركات</div>\n                <div data-label