;\n  margin:15px 0 8px 0;\n}\n\n/* ===== CTA ===== */\n.tv-cta{\n  margin-top:25px;\n  text-align:center;\n}\n\n.tv-cta-title{\n  font-size:13px;\n  margin-bottom:10px;\n}\n\n.tv-cta a{\n  display:inline-block;\n  padding:8px 22px;\n  font-size:12px;\n  background:#3fa9ff;\n  color:#fff;\n  text-decoration:none;\n  border-radius:18px;\n  transition:.3s ease;\n}\n\n.tv-cta a:hover{\n  background:#2d8be0;\n}\n</style>\n\n<!-- زر الوضع -->\n<div class=\"tv-theme-toggle\">\n  <button onclick=\"toggleTheme()\" id=\"themeIcon\">🌙</button>\n</div>\n\n<div class=\"tv-card\">\n\n<h1 class=\"tv-title\">طريقة توصيل تطبيق للتحكم بالتلفاز الذكي</h1>\n\n<div class=\"tv-content-box\">\n\n<div class=\"tv-subtitle\">1️⃣ التأكد من المتطلبات الأساسية</div>\nأن يكون التلفاز Smart TV ويدعم الاتصال عبر Wi-Fi.<br>\nالهاتف والتلفاز متصلان بنفس شبكة Wi-Fi.<br>\nتحديث نظام التلفاز لأحدث إصدار.<br>\nتفعيل خيار Remote / Device Connection / Network Remote من إعدادات التلفاز.\n\n<br><br>\n\n<div class=\"tv-subtitle\">📱 ربط الهاتف بالتلفاز</div>\nافتح التطبيق.<br>\nاختر إضافة جهاز / Add Device.<br>\nسيبدأ التطبيق بالبحث عن التلفاز تلقائيًا.<br>\nعند ظهور اسم التلفاز اضغط عليه.<br>\nسيظهر رمز تحقق (PIN) على شاشة التلفاز.<br>\nأدخل الرمز في الهاتف لإتمام الاقتران.\n\n<br><br>\n\n<div class=\"tv-subtitle\">❗ في حال لم يظهر التلفاز</div>\nأعد تشغيل الراوتر.<br>\nأعد تشغيل التلفاز.<br>\nتأكد من تعطيل VPN.<br>\nجرّب الاتصال عبر Bluetooth إذا كان مدعومًا.<br>\nتحقق من أن خاصية Screen Mirroring / Cast مفعلة.\n\n<br><br>\n\n<div class=\"tv-subtitle\">🔄 حل بديل (بدون Wi-Fi)</div>\nإذا كان الهاتف يحتوي على IR Blaster:<br>\nحمّل تطبيق تحكم عام مثل Mi Remote.<br>\nاختر نوع التلفاز.<br>\nوجّه الهاتف نحو التلفاز مباشرة.\n\n</div>\n\n<div class=\"tv-cta\">\n  <div class=\"tv-cta-title\">تحميل التطبيقات</div>\n  <a href=\"https://t.me/techtouch7/4853?single\" target=\"_blank\">\n    اضغط هنا\n  </a>\n</div>\n\n</div>\n\n<script>\nfunction toggleTheme(){\n  const root=document.documentElement;\n  const btn=document.getElementById('themeIcon');\n\n  root.classList.toggle('light-mode');\n\n  if(root.classList.contains('light-mode')){\n    btn.textContent='☀';\n    localStorage.setItem('theme','light');\n  }else{\n    btn.textContent='🌙';\n    localStorage.setItem('theme','dark');\n  }\n}\n\nwindow.addEventListener('DOMContentLoaded',()=>{\n  const savedTheme=localStorage.getItem('theme');\n  const btn=document.getElementById('themeIcon');\n  if(savedTheme==='light'){\n    document.documentElement.classList.add('light-mode');\n    btn.textContent='☀';\n  }\n});\n</script>\n\n</section>",
