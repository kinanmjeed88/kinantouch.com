  "content": "<!DOCTYPE html>\n<html lang=\"ar\" dir=\"rtl\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>برشلونة × باريس سان جيرمان | بث مباشر</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;800&display=swap\" rel=\"stylesheet\">\n\n<style>\n.barca-psg-container * {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n  font-family: 'Cairo', sans-serif;\n}\n\n.barca-psg-container {\n  font-family: 'Cairo', sans-serif;\n  background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);\n  color: #fff;\n  padding: 15px;\n  border-radius: 12px;\n  max-width: 500px;\n  margin: 0 auto;\n  direction: rtl;\n}\n\n.barca-card {\n  background: rgba(0,0,0,0.75);\n  border-radius: 18px;\n  padding: 20px;\n  box-shadow: 0 10px 25px rgba(0,0,0,0.4);\n  text-align: center;\n}\n\n.barca-note {\n  background: rgba(255, 255, 0, 0.1);\n  border: 1px solid rgba(255, 255, 0, 0.3);\n  border-radius: 10px;\n  padding: 12px 15px;\n  margin-bottom: 15px;\n  text-align: right;\n  font-size: 13px;\n  color: #ffeb3b;\n  line-height: 1.5;\n}\n\n.barca-request-text {\n  font-size: 12px;\n  color: #ffeb3b;\n  margin-bottom: 5px;\n  font-weight: 600;\n  text-align: center;\n}\n\n.barca-bot-link {\n  display: inline-block;\n  color: #1e90ff;\n  font-weight: 800;\n  font-size: 15px;\n  text-decoration: none;\n  margin-bottom: 15px;\n}\n\n.barca-live {\n  font-size: 14px;\n  margin-bottom: 15px;\n  font-weight: 700;\n}\n\n.barca-live-dot {\n  color: red;\n  animation: barca-blink 1s infinite;\n}\n\n@keyframes barca-blink {\n  50% { opacity: 0.2; }\n}\n\n.barca-teams {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: 10px;\n  margin-bottom: 20px;\n}\n\n.barca-team {\n  flex: 1;\n}\n\n.barca-team img {\n  width: 60px;\n  height: 60px;\n  object-fit: contain;\n}\n\n.barca-team h2 {\n  font-size: 14px;\n  margin-top: 5px;\n  color: #fff;\n}\n\n.barca-vs {\n  font-weight: 800;\n  font-size: 18px;\n  color: gold;\n}\n\n.barca-section-title {\n  font-size: 16px;\n  margin: 20px 0 12px 0;\n  color: gold;\n  text-align: right;\n  padding-right: 5px;\n  border-bottom: 1px solid rgba(255,215,0,0.3);\n  padding-bottom: 5px;\n}\n\n.barca-links {\n  display: flex;\n  flex-direction: column;\n  gap: 12px;\n  margin-bottom: 5px;\n}\n\n.barca-btn {\n  display: block;\n  text-decoration: none;\n  background: gold;\n  color: #000;\n  padding: 10px;\n  border-radius: 30px;\n  font-weight: 700;\n  font-size: 14px;\n  transition: 0.3s;\n  text-align: center;\n}\n\n.barca-btn:hover {\n  background: #fff;\n  transform: translateY(-2px);\n}\n\n.barca-quality {\n  font-size: 12px;\n  color: #666;\n  margin-top: 3px;\n  text-align: center;\n}\n\n.barca-meta {\n  display: flex;\n  justify-content: space-between;\n  font-size: 12px;\n  color: #aaa;\n  margin-top: 15px;\n  padding-top: 10px;\n  border-top: 1px solid rgba(255,255,255,0.1);\n}\n\n@media screen and (max-width: 480px) {\n  .barca-psg-container { padding: 10px; }\n  .barca-card { padding: 15px; }\n  .barca-team img { width: 50px; height: 50px; }\n}\n</style>\n</head>\n\n<body>\n\n<div class=\"barca-psg-container\">\n  <div class=\"barca-card\">\n\n    <div class=\"barca-note\">\n      ⚠️ يتم تحديث الروابط باستمرار.\n    </div>\n\n    <div class=\"barca-request-text\">\n      لطلب روابط بث مباشر اضغط على البوت\n    </div>\n\n    <div style=\"text-align:center;\">\n      <a href=\"https://t.me/techtouchAI_bot\" class=\"barca-bot-link\" target=\"_blank\">\n        @techtouchAI_bot\n      </a>\n    </div>\n    \n    <div class=\"barca-live\">\n      <span class=\"barca-live-dot\">●</span> بث مباشر\n    </div>\n\n    <div class=\"barca-teams\">\n      <div class=\"barca-team\">\n        <img src=\"https://upload.wikimedia.org/wikipedia/ar/thumb/4/47/FC_Barcelona_%28crest%29.svg/1200px-FC_Barcelona_%28crest%29.svg.png\" \n             alt=\"شعار نادي برشلونة\" loading=\"lazy\">\n        <h2>برشلونة</h2>\n      </div>\n\n      <div class=\"barca-vs\">VS</div>\n\n      <div class=\"barca-team\">\n        <img src=\"https://upload.wikimedia.org/wikipedia/en/a/a7/Paris_Saint-Germain_F.C..svg\" \n             alt=\"شعار نادي باريس سان جيرمان\" loading=\"lazy\">\n        <h2>باريس سان جيرمان</h2>\n      </div>\n    </div>\n\n    <div class=\"barca-section-title\">📺 روابط البث الأساسية</div>\n    <div class=\"barca-links\">\n      <a class=\"barca-btn\" href=\"#\">رابط البث المباشر (1)</a>\n      <a class=\"barca-btn\" href=\"#\">رابط البث المباشر (2)</a>\n      <a class=\"barca-btn\" href=\"#\">رابط البث المباشر (3)</a>\n    </div>\n\n    <div class=\"barca-section-title\">📡 روابط للإنترنت المتوسط</div>\n    <div class=\"barca-links\">\n      <a class=\"barca-btn\" href=\"#\">\n        رابط الإنترنت المتوسط (1)\n        <div class=\"barca-quality\">جودة متوسطة - سرعة تحميل جيدة</div>\n      </a>\n      <a class=\"barca-btn\" href=\"#\">\n        رابط الإنترنت المتوسط (2)\n        <div class=\"barca-quality\">بث سلس للاتصالات المتوسطة</div>\n      </a>\n      <a class=\"barca-btn\" href=\"#\">\n        رابط الإنترنت المتوسط (3)\n        <div class=\"barca-quality\">روابط إضافية بديلة</div>\n      </a>\n    </div>\n\n    <div class=\"barca-meta\">\n      <span>⏰ الوقت المتبقي: --:--</span>\n      <span>👁️ المشاهدون: 2.4K</span>\n    </div>\n\n  </div>\n</div>\n\n<script>\ndocument.addEventListener('DOMContentLoaded', function() {\n  const metaEl = document.querySelector('.barca-meta');\n  if (metaEl) {\n    const updateTime = () => {\n      const now = new Date();\n      const hours = String(now.getHours()).padStart(2, '0');\n      const minutes = String(now.getMinutes()).padStart(2, '0');\n      metaEl.innerHTML = `<span>🕐 آخر تحديث: ${hours}:${minutes}</span>\n                          <span>📊 حالة البث: 🔴 مباشر</span>`;\n    };\n    updateTime();\n    setInterval(updateTime, 60000);\n  }\n\n  const buttons = document.querySelectorAll('.barca-btn');\n  buttons.forEach(btn => {\n    btn.addEventListener('click', function(e) {\n      e.preventDefault();\n      this.style.transform = 'scale(0.98)';\n      setTimeout(() => { this.style.transform = ''; }, 200);\n    });\n  });\n});\n</script>\n\n</body>\n</html> ",
