iframe {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            border: none;\n            display: block;\n        }\n\n        /* ── CARDS GRID ── */\n        .cards-grid {\n            display: grid;\n            grid-template-columns: 1fr 1fr;\n            gap: 16px;\n            margin-bottom: 28px;\n            animation: fadeUp 0.6s ease 0.2s both;\n        }\n\n        @media (max-width: 600px) {\n            .cards-grid { grid-template-columns: 1fr; }\n        }\n\n        .info-card {\n            border-radius: 16px;\n            padding: 22px;\n            border: 1px solid;\n            position: relative;\n            overflow: hidden;\n            transition: transform 0.2s ease, box-shadow 0.2s ease;\n        }\n\n        .info-card:hover {\n            transform: translateY(-2px);\n        }\n\n        .info-card::before {\n            content: '';\n            position: absolute;\n            top: 0; right: 0;\n            width: 80px; height: 80px;\n            border-radius: 50%;\n            filter: blur(30px);\n            opacity: 0.4;\n        }\n\n        .info-card.green {\n            background: var(--accent-green-glow);\n            border-color: rgba(52, 211, 153, 0.2);\n            box-shadow: 0 4px 20px rgba(52, 211, 153, 0.06);\n        }\n\n        .info-card.green::before {\n            background: var(--accent-green);\n        }\n\n        .info-card.red {\n            background: var(--accent-red-glow);\n            border-color: rgba(248, 113, 113, 0.2);\n            box-shadow: 0 4px 20px rgba(248, 113, 113, 0.06);\n        }\n\n        .info-card.red::before {\n            background: var(--accent-red);\n        }\n\n        .card-icon-title {\n            display: flex;\n            align-items: center;\n            gap: 10px;\n            margin-bottom: 14px;\n            padding-bottom: 14px;\n            border-bottom: 1px solid;\n        }\n\n        .info-card.green .card-icon-title {\n            border-color: rgba(52, 211, 153, 0.2);\n        }\n\n        .info-card.red .card-icon-title {\n            border-color: rgba(248, 113, 113, 0.2);\n        }\n\n        .card-icon {\n            width: 36px;\n            height: 36px;\n            border-radius: 10px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 16px;\n            flex-shrink: 0;\n        }\n\n        .info-card.green .card-icon {\n            background: rgba(52, 211, 153, 0.15);\n            color: var(--accent-green);\n        }\n\n        .info-card.red .card-icon {\n            background: rgba(248, 113, 113, 0.15);\n            color: var(--accent-red);\n        }\n\n        .card-title {\n            font-size: 15px;\n            font-weight: 800;\n        }\n\n        .info-card.green .card-title { color: var(--accent-green); }\n        .info-card.red .card-title { color: var(--accent-red); }\n\n        .card-body {\n            font-size: 13.5px;\n            line-height: 1.85;\n            color: var(--text-secondary);\n            position: relative;\n        }\n\n        .card-body strong {\n            color: var(--text-primary);\n            font-weight: 700;\n        }\n\n        /* ── STEPS SECTION ── */\n        .steps-section {\n            background: var(--bg-card);\n            border: 1px solid var(--border-color);\n            border-radius: 20px;\n            padding: 28px;\n            margin-bottom: 20px;\n            animation: fadeUp 0.6s ease 0.3s both;\n            transition: box-shadow 0.2s ease;\n        }\n\n        .steps-section:hover {\n            box-shadow: 0 8px 40px rgba(0, 0, 0, 0.3);\n        }\n\n        .section-header {\n            display: flex;\n            align-items: center;\n            gap: 12px;\n            margin-bottom: 22px;\n            padding-bottom: 18px;\n            border-bottom: 1px solid var(--border-color);\n        }\n\n        .os-icon {\n            width: 44px;\n            height: 44px;\n            border-radius: 12px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 22px;\n            flex-shrink: 0;\n        }\n\n        .os-icon.android {\n            background: rgba(52, 211, 153, 0.12);\n            color: var(--accent-green);\n        }\n\n        .os-icon.ios {\n            background: rgba(226, 232, 240, 0.08);\n            color: #e2e8f0;\n        }\n\n        .section-title {\n            font-size: 18px;\n            font-weight: 800;\n            color: var(--text-primary);\n        }\n\n        .section-subtitle {\n            font-size: 12px;\n            color: var(--text-secondary);\n            margin-top: 2px;\n        }\n\n        .steps-list {\n            list-style: none;\n            display: flex;\n            flex-direction: column;\n            gap: 10px;\n        }\n\n        .step-item {\n            display: flex;\n            align-items: flex-start;\n            gap: 14px;\n            background: var(--step-bg);\n            border: 1px solid var(--step-border);\n            border-radius: 12px;\n            padding: 14px 16px;\n            transition: border-color 0.2s ease, background 0.2s ease;\n        }\n\n        .step-item:hover {\n            border-color: rgba(77, 140, 245, 0.3);\n            background: var(--bg-card-hover);\n        }\n\n        .step-num {\n            min-width: 28px;\n            height: 28px;\n            border-radius: 8px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 13px;\n            font-weight: 900;\n            flex-shrink: 0;\n            margin-top: 1px;\n        }\n\n        .android-num {\n            background: rgba(52, 211, 153, 0.15);\n            color: var(--accent-green);\n        }\n\n        .ios-num {\n            background: rgba(226, 232, 240, 0.08);\n            color: #94a3b8;\n        }\n\n        .step-text {\n            font-size: 14px;\n            color: var(--text-secondary);\n            line-height: 1.75;\n            padding-top: 3px;\n        }\n\n        .step-text strong {\n            color: var(--text-primary);\n            font-weight: 700;\n        }\n\n        /* ── TIP BOX ── */\n        .tip-box {\n            display: flex;\n            align-items: flex-start;\n            gap: 14px;\n            background: var(--accent-blue-glow);\n            border: 1px solid rgba(77, 140, 245, 0.2);\n            border-radius: 14px;\n            padding: 18px 20px;\n            margin-top: 20px;\n            animation: fadeUp 0.6s ease 0.4s both;\n        }\n\n        .tip-icon {\n            font-size: 18px;\n            color: var(--accent-blue);\n            margin-top: 2px;\n            flex-shrink: 0;\n        }\n\n        .tip-text {\n            font-size: 13.5px;\n            color: var(--text-secondary);\n            line-height: 1.8;\n        }\n\n        .tip-text strong {\n            color: var(--accent-blue);\n            font-weight: 700;\n        }\n\n        /* ── ANIMATIONS ── */\n        @keyframes fadeUp {\n            from { opacity: 0; transform: translateY(18px); }\n            to   { opacity: 1; transform: translateY(0); }\n        }\n\n        /* ── SCROLLBAR ── */\n        ::-webkit-scrollbar { width: 6px; }\n        ::-webkit-scrollbar-track { background: var(--bg-primary); }\n        ::-webkit-scrollbar-thumb { background: var(--border-color); border-radius: 3px; }\n        ::-webkit-scrollbar-thumb:hover { background: #3a4a6a; }\n    </style>\n</head>\n<body>\n\n<div class=\"page-wrapper\">\n\n    <!-- HERO HEADER -->\n    <div class=\"hero-header\">\n        <div class=\"hero-badge\">\n            <i class=\"fas fa-wifi\"></i>\n            دليل تقني شامل\n        </div>\n        <h1 class=\"hero-title\">\n            طريقة إلغاء <span>DNS الخاص</span> من هاتفك\n        </h1>\n        <p class=\"hero-subtitle\">\n            يُعد نظام أسماء النطاقات الخاص (Private DNS) سلاحاً تقنياً فعالاً، لكنه قد يكون السبب الرئيسي في عزل هاتفك عن الشبكات المحلية وتوقف تطبيقاتك المفضلة.\n        </p>\n    </div>\n\n    <!-- VIDEO - Shorts embed (9:16) -->\n    <div class=\"video-wrapper\">\n        <div class=\"video-container\">\n            <iframe\n                src=\"https://www.youtube.com/embed/S1zjBi-Afz4\"\n                title=\"طريقة إلغاء DNS من الهاتف\"\n                allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\"\n                allowfullscreen\n                loading=\"lazy\">\n            </iframe>\n        </div>\n    </div>\n\n    <!-- PROS / CONS CARDS -->\n    <div class=\"cards-grid\">\n\n        <div class=\"info-card green\">\n            <div class=\"card-icon-title\">\n                <div class=\"card-icon\">\n                    <i class=\"fas fa-shield-alt\"></i>\n                </div>\n                <div class=\"card-title\">فوائد DNS المخصص</div>\n            </div>\n            <div class=\"card-body\">\n                استخدام سيرفرات مثل <strong>AdGuard</strong> يمنحك حجباً شاملاً للإعلانات المزعجة والنوافذ المنبثقة داخل المتصفحات والتطبيقات، بدون برامج خارجية، مع تسريع الاستجابة وحماية خصوصيتك من التتبع.\n            </div>\n        </div>\n\n        <div class=\"info-card red\">\n            <div class=\"card-icon-title\">\n                <div class=\"card-icon\">\n                    <i class=\"fas fa-exclamation-triangle\"></i>\n                </div>\n                <div class=\"card-title\">لماذا نضطر لإلغائه؟</div>\n            </div>\n            <div class=\"card-body\">\n                التطبيقات المحلية تعتمد على سيرفرات مزود الإنترنت (ISP). تفعيل DNS خارجي يمنع الاتصال بالشبكة المحلية، مما يوقف تطبيقات مثل <strong>سينمانا · CEE · شبكتي</strong> تماماً.\n            </div>\n        </div>\n\n    </div>\n\n    <!-- ANDROID STEPS -->\n    <div class=\"steps-section\">\n        <div class=\"section-header\">\n            <div class=\"os-icon android\">\n                <i class=\"fab fa-android\"></i>\n            </div>\n            <div>\n                <div class=\"section-title\">أجهزة أندرويد (Android)</div>\n                <div class=\"section-subtitle\">يعمل على معظم إصدارات Android 9 وما فوق</div>\n            </div>\n        </div>\n        <ol class=\"steps-list\">\n            <li class=\"step-item\">\n                <span class=\"step-num android-num\">١</span>\n                <span class=\"step-text\">افتح <strong>الإعدادات (Settings)</strong> في هاتفك.</span>\n            </li>\n            <li class=\"step-item\">\n                <span class=\"step-num android-num\">٢</span>\n                <span class=\"step-text\">انتقل إلى <strong>الاتصالات (Connections)</strong> أو <strong>الشبكة والإنترنت (Network & Internet)</strong>.</span>\n            </li>\n            <li class=\"step-item\">\n                <span class=\"step-num android-num\">٣</span>\n                <span class=\"step-text\">اضغط على <strong>المزيد من إعدادات الاتصال</strong>، ثم اختر <strong>نظام أسماء النطاقات الخاص (Private DNS)</strong>.</span>\n            </li>\n            <li class=\"step-item\">\n                <span class=\"step-num android-num\">٤</span>\n                <span class=\"step-text\">حدد خيار <strong>إيقاف (Off)</strong> أو <strong>تلقائي (Automatic)</strong>، ثم اضغط <strong>حفظ (Save)</strong>.</span>\n            </li>\n        </ol>\n    </div>\n\n    <!-- iOS STEPS -->\n    <div class=\"steps-section\">\n        <div class=\"section-header\">\n            <div class=\"os-icon ios\">\n                <i class=\"fab fa-apple\"></i>\n            </div>\n            <div>\n                <div class=\"section-title\">أجهزة آيفون (iOS)</div>\n                <div class=\"section-subtitle\">يُطبَّق لكل شبكة Wi-Fi بشكل مستقل</div>\n            </div>\n        </div>\n        <ol class=\"steps-list\">\n            <li class=\"step-item\">\n                <span class=\"step-num ios-num\">١</span>\n                <span class=\"step-text\">افتح <strong>الإعدادات (Settings)</strong> واختر <strong>Wi-Fi</strong>.</span>\n            </li>\n            <li class=\"step-item\">\n                <span class=\"step-num ios-num\">٢</span>\n                <span class=\"step-text\">اضغط على <strong>أيقونة المعلومات (i)</strong> بجوار اسم الشبكة المتصل بها.</span>\n            </li>\n            <li class=\"step-item\">\n                <span class=\"step-num ios-num\">٣</span>\n                <span class=\"step-text\">مرر للأسفل واضغط على <strong>تكوين DNS (Configure DNS)</strong>.</span>\n            </li>\n            <li class=\"step-item\">\n                <span class=\"step-num ios-num\">٤</span>\n                <span class=\"step-text\">غيّر الخيار من \"يدوي\" إلى <strong>تلقائي (Automatic)</strong>، ثم اضغط <strong>حفظ (Save)</strong> في الزاوية العلوية.</span>\n            </li>\n        </ol>\n    </div>\n\n    <!-- TIP -->\n    <div class=\"tip-box\">\n        <i class=\"fas fa-lightbulb tip-icon\"></i>\n        <p class=\"tip-text\">\n            <strong>نصيحة:</strong> إذا أردت الاستفادة من حجب الإعلانات مع الحفاظ على التطبيقات المحلية، يمكنك <strong>تفعيل DNS المخصص عند الحاجة فقط</strong> ثم إيقافه عند استخدام تلك التطبيقات. بعض الأجهزة تدعم إضافة استثناءات من خلال تطبيقات VPN المتخصصة.\n        </p>\n    </div>\n\n</div>\n\n</body>\n</html>\n",
