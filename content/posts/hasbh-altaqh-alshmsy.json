  "content": "<script>!function(){if(document.querySelector('script[src*=\"cdn.tailwindcss\"]'))return;var t=document.createElement('script');t.src='https://cdn.tailwindcss.com';t.onload=function(){if(window.tailwind)tailwind.config={darkMode:'class',theme:{extend:{fontFamily:{sans:['Tajawal','sans-serif']}}}};};document.head.appendChild(t);}();</script>\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link href=\"https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;900&display=swap\" rel=\"stylesheet\">\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css\">\n\n<div class=\"font-[Tajawal] text-base leading-relaxed text-gray-900 bg-white p-2 md:p-6\" dir=\"rtl\">\n\n    <!-- العنوان الرئيسي -->\n    <h1 class=\"text-2xl md:text-4xl font-black text-center mb-4 bg-gradient-to-r from-yellow-600 to-orange-600 bg-clip-text text-transparent leading-tight\">\n        Solar Expert Calculator: المساعد الشخصي لتصميم منظومات الطاقة الشمسية\n    </h1>\n\n    <p class=\"text-lg text-gray-800 leading-relaxed mb-6 text-center font-bold px-4\">\n        التطبيق الهندسي الأول الذي يغنيك عن التخمين. صمم نظامك بالكامل بدقة علمية مطابقة لمعايير (NEC) العالمية، واحصل على تقارير فنية بضغطة زر.\n    </p>\n\n    <!-- شارة الفخر (التصميم والبرمجة) -->\n    <div class=\"text-center mb-10\">\n        <span class=\"inline-flex flex-wrap justify-center items-center gap-3 bg-slate-50 border border-slate-200 text-slate-700 px-6 py-3 rounded-full text-sm md:text-base font-black shadow-sm\">\n            <span class=\"flex items-center gap-2\"><i class=\"fas fa-lightbulb text-orange-500 text-lg\"></i> فكرة وتصميم هندسي: المطور</span>\n            <span class=\"text-slate-300 hidden sm:inline\">|</span>\n            <span class=\"flex items-center gap-2\"><i class=\"fas fa-robot text-emerald-600 text-lg\"></i> تمت البرمجة كلياً بواسطة الذكاء الاصطناعي (AI)</span>\n        </span>\n    </div>\n\n    <!-- بطاقات الإحصائيات السريعة -->\n    <section class=\"bg-slate-900 text-white rounded-3xl p-6 md:p-8 mb-10 shadow-2xl overflow-hidden\">\n        <div class=\"grid grid-cols-1 sm:grid-cols-3 gap-4\">\n            <div class=\"bg-slate-800 p-4 rounded-2xl text-center border border-slate-700\">\n                <div class=\"text-yellow-500 text-2xl mb-2\"><i class=\"fas fa-bolt\"></i></div>\n                <div class=\"text-xl font-black\">حسابات دقيقة</div>\n                <div class=\"text-xs text-slate-400 font-bold\">إدخال بالواط، الأمبير، أو الطن</div>\n            </div>\n            <div class=\"bg-slate-800 p-4 rounded-2xl text-center border border-slate-700\">\n                <div class=\"text-emerald-500 text-2xl mb-2\"><i class=\"fas fa-file-pdf\"></i></div>\n                <div class=\"text-xl font-black\">تقارير PDF</div>\n                <div class=\"text-xs text-slate-400 font-bold\">هندسية جاهزة للطباعة والمشاركة</div>\n            </div>\n            <div class=\"bg-slate-800 p-4 rounded-2xl text-center border border-slate-700\">\n                <div class=\"text-blue-500 text-2xl mb-2\"><i class=\"fas fa-shield-alt\"></i></div>\n                <div class=\"text-xl font-black\">مطابق NEC</div>\n                <div class=\"text-xs text-slate-400 font-bold\">حساب القواطع (DC/AC) والأسلاك</div>\n            </div>\n        </div>\n    </section>\n\n    <!-- المميزات الأساسية وطرق الحساب -->\n    <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6 mb-10\">\n        \n        <!-- قسم ماذا يحسب التطبيق -->\n        <section class=\"bg-orange-50 border border-orange-100 rounded-3xl p-6 shadow-sm\">\n            <h3 class=\"font-black text-xl mb-5 text-orange-800 border-r-4 border-orange-500 pr-3\">تصميم المنظومة بالكامل</h3>\n            <ul class=\"space-y-4 font-bold text-gray-800 text-sm md:text-base\">\n                <li class=\"flex items-start gap-3\"><i class=\"fas fa-solar-panel text-orange-500 mt-1\"></i> <span><strong>الألواح والبطاريات:</strong> حساب علمي لعدد الألواح، وحجم بنك البطاريات (سواء كانت ليثيوم أو جل).</span></li>\n                <li class=\"flex items-start gap-3\"><i class=\"fas fa-microchip text-orange-500 mt-1\"></i> <span><strong>توصيات الإنفرتر الذكية:</strong> يحلل أحمالك ويرشح النظام الأنسب (Hybrid, Off-Grid, On-Grid, UPS).</span></li>\n                <li class=\"flex items-start gap-3\"><i class=\"fas fa-money-bill-wave text-orange-500 mt-1\"></i> <span><strong>حساب التكاليف المحلية:</strong> تسعير دقيق للمنظومة (بالدولار والدينار العراقي)، ويحسب لك (كم ورقة).</span></li>\n            </ul>\n        </section>\n\n        <!-- قسم طرق الحساب -->\n        <section class=\"bg-emerald-50 border border-emerald-100 rounded-3xl p-6 shadow-sm\">\n            <h3 class=\"font-black text-xl mb-5 text-emerald-800 border-r-4 border-emerald-500 pr-3\">طريقتان مرنتان للحساب</h3>\n            <ul class=\"space-y-4 font-bold text-gray-800 text-sm md:text-base\">\n                <li class=\"flex items-start gap-3\"><i class=\"fas fa-list-ol text-emerald-600 mt-1 text-lg\"></i> <span><strong>الطريقة الأولى (التفصيلية):</strong> الحساب حسب عدد الأجهزة المدخلة وتفاصيل تشغيلها.</span></li>\n                <li class=\"flex items-start gap-3\"><i class=\"fas fa-stopwatch text-emerald-600 mt-1 text-lg\"></i> <span><strong>الطريقة الثانية (السريعة):</strong> الحساب المباشر حسب الأمبير الكلي المطلوب وساعات التشغيل.</span></li>\n            </ul>\n        </section>\n    </div>\n\n    <!-- قسم الميزات الاستثنائية والحصرية -->\n    <section class=\"bg-slate-50 border border-slate-200 rounded-3xl p-6 shadow-sm mb-12\">\n        <h3 class=\"font-black text-xl mb-6 text-slate-800 border-r-4 border-slate-500 pr-3\">ميزات أخرى (حالات الحساب المخصصة)</h3>\n        <div class=\"grid grid-cols-2 md:grid-cols-4 gap-4\">\n            <div class=\"bg-white p-4 rounded-2xl border border-slate-200 text-center shadow-sm hover:border-blue-400 transition-colors\">\n                <i class=\"fas fa-sun text-3xl text-yellow-500 mb-3 block\"></i>\n                <span class=\"font-black text-slate-700 text-sm\">الحساب بدون بطاريات</span>\n            </div>\n            <div class=\"bg-white p-4 rounded-2xl border border-slate-200 text-center shadow-sm hover:border-blue-400 transition-colors\">\n                <i class=\"fas fa-battery-half text-3xl text-emerald-500 mb-3 block\"></i>\n                <span class=\"font-black text-slate-700 text-sm\">الحساب بدون ألواح (UPS)</span>\n            </div>\n            <div class=\"bg-white p-4 rounded-2xl border border-slate-200 text-center shadow-sm hover:border-blue-400 transition-colors\">\n                <i class=\"fas fa-house-damage text-3xl text-orange-500 mb-3 block\"></i>\n                <span class=\"font-black text-slate-700 text-sm\">الحساب بدون كهرباء وطنية</span>\n            </div>\n            <div class=\"bg-white p-4 rounded-2xl border border-slate-200 text-center shadow-sm hover:border-blue-400 transition-colors\">\n                <i class=\"fas fa-clock text-3xl text-blue-500 mb-3 block\"></i>\n                <span class=\"font-black text-slate-700 text-sm\">حسب أوقات توفر الكهرباء</span>\n            </div>\n        </div>\n    </section>\n\n    <!-- قسم التحميل المتعدد -->\n    <div class=\"text-center border-t border-gray-200 pt-10\">\n        <h3 class=\"font-black text-2xl text-gray-900 mb-2\"><i class=\"fas fa-cloud-arrow-down ml-2 text-orange-600\"></i>روابط التحميل المباشرة</h3>\n        <p class=\"text-sm text-gray-500 mb-8 font-bold\">اختر النسخة المتوافقة مع معالج هاتفك:</p>\n        \n        <div class=\"flex flex-wrap justify-center gap-4 max-w-5xl mx-auto\">\n            \n            <!-- زر ميديا فاير - 64 بت -->\n            <a href=\"https://www.mediafire.com/file/nf3ddhfvrenno6j/solar_calculator_64-v8.apk/file\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"flex-1 min-w-[280px] flex items-center justify-center gap-4 bg-slate-800 text-white py-4 px-6 rounded-2xl shadow-xl hover:-translate-y-1 hover: