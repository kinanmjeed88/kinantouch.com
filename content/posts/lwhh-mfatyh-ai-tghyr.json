الميزات الدقيقة -->\n        <div class=\"grid md:grid-cols-2 gap-6 mb-12\">\n\n            <div class=\"p-6 rounded-3xl bg-white/70 dark:bg-white/5 backdrop-blur-xl shadow-lg\">\n                <h3 class=\"font-bold text-blue-600 mb-3\">التدقيق اللغوي والكتابة</h3>\n                <ul class=\"space-y-1\">\n                    <li>تصحيح القواعد النحوية والإملائية.</li>\n                    <li>إكمال الجمل.</li>\n                    <li>تفسير الأخطاء.</li>\n                    <li>كتابة المقالات.</li>\n                    <li>إعادة الصياغة.</li>\n                </ul>\n            </div>\n\n            <div class=\"p-6 rounded-3xl bg-white/70 dark:bg-white/5 backdrop-blur-xl shadow-lg\">\n                <h3 class=\"font-bold text-blue-600 mb-3\">المساعد الذكي</h3>\n                <ul class=\"space-y-1\">\n                    <li>GPT-4o و GPT-4o mini.</li>\n                    <li>100+ بوت.</li>\n                    <li>بوت مخصص.</li>\n                    <li>إجابات فورية.</li>\n                    <li>ردود ذكية.</li>\n                </ul>\n            </div>\n\n            <div class=\"p-6 rounded-3xl bg-white/70 dark:bg-white/5 backdrop-blur-xl shadow-lg\">\n                <h3 class=\"font-bold text-blue-600 mb-3\">الترجمة</h3>\n                <ul class=\"space-y-1\">\n                    <li>ترجمة عالمية.</li>\n                    <li>ترجمة الصور وPDF.</li>\n                    <li>دعم لغات متعددة.</li>\n                </ul>\n            </div>\n\n            <div class=\"p-6 rounded-3xl bg-white/70 dark:bg-white/5 backdrop-blur-xl shadow-lg\">\n                <h3 class=\"font-bold text-blue-600 mb-3\">التخصيص</h3>\n                <ul class=\"space-y-1\">\n                    <li>100+ Theme.</li>\n                    <li>60+ خط.</li>\n                    <li>2000 Emoji.</li>\n                </ul>\n            </div>\n\n        </div>\n\n        <!-- الأمان -->\n        <div class=\"bg-yellow-100/80 dark:bg-yellow-900/30 border border-yellow-400 rounded-3xl p-6 mb-12 shadow-xl\">\n            <h3 class=\"font-bold mb-2\">الأمان والخصوصية</h3>\n            <p>تأكد دائماً من مراجعة الأذونات واستخدام النسخ الرسمية.</p>\n        </div>\n\n        <!-- التحميل -->\n        <div class=\"text-center\">\n            <div class=\"flex flex-col sm:flex-row justify-center gap-4\">\n\n                <a href=\"https://play.google.com/store/apps/details?id=starnest.aitype.aikeyboard.chatbot.chatgpt\"\n                   target=\"_blank\"\n                   class=\"inline-flex items-center justify-center gap-3 bg-black dark:bg-white text-white dark:text-black px-8 py-4 rounded-2xl font-bold shadow-2xl hover:scale-105 transition\">\n                    <i class=\"fab fa-google-play\"></i>\n                    تثبيت من Google Play\n                </a>\n\n                <a href=\"https://t.me/techtouch7/1733\"\n                   target=\"_blank\"\n                   class=\"inline-flex items-center justify-center gap-3 bg-[#24A1DE] text-white px-8 py-4 rounded-2xl font-bold shadow-2xl hover:scale-105 transition\">\n                    <i class=\"fab fa-telegram-plane\"></i>\n                    تابعنا على تيليجرام\n                </a>\n\n            </div>\n        </div>\n\n    </div>\n</div>",
