  "content": "<section class=\"siri-article\">\n\n<style>\nhtml{\n  transition:background .4s ease,color .4s ease;\n}\n\nbody{\n  margin:0;\n  font-family:'Tajawal',sans-serif;\n  background:#0b0c11;\n  color:#ffffff;\n  transition:.4s ease;\n}\n\n/* ===== الوضع النهاري الكامل ===== */\nhtml.light-mode body{\n  background:#f4f6fb;\n  color:#111;\n}\n\n/* ===== زر عائم زجاجي يسار ===== */\n.siri-theme-toggle{\n  position:fixed;\n  top:15px;\n  left:15px;\n  z-index:9999;\n}\n\n.siri-theme-toggle button{\n  width:38px;\n  height:38px;\n  border-radius:50%;\n  border:1px solid rgba(255,255,255,0.25);\n  background:rgba(255,255,255,0.08);\n  backdrop-filter:blur(16px);\n  -webkit-backdrop-filter:blur(16px);\n  color:#ffffff;\n  font-size:16px;\n  cursor:pointer;\n  display:flex;\n  align-items:center;\n  justify-content:center;\n  transition:.3s ease;\n  box-shadow:0 8px 20px rgba(0,0,0,0.4);\n}\n\n.siri-theme-toggle button:hover{\n  transform:scale(1.1);\n  background:rgba(255,255,255,0.15);\n}\n\nhtml.light-mode .siri-theme-toggle button{\n  background:rgba(255,255,255,0.7);\n  color:#111;\n  border:1px solid rgba(0,0,0,0.1);\n}\n\n/* ===== الحاوية ===== */\n.siri-article{\n  width:100%;\n  padding:100px 15px 80px 15px;\n  display:flex;\n  justify-content:center;\n}\n\n.siri-card{\n  width:100%;\n  max-width:1000px;\n  padding:60px 6vw;\n  border-radius:30px;\n  background:linear-gradient(180deg,#0f111a,#0b0c11);\n  box-shadow:\n    inset 0 0 120px rgba(0,0,0,0.9),\n    0 40px 100px rgba(0,0,0,0.7);\n  transition:.4s ease;\n}\n\nhtml.light-mode .siri-card{\n  background:#ffffff;\n  box-shadow:0 40px 80px rgba(0,0,0,0.08);\n}\n\n/* ===== العنوان ===== */\n.siri-title{\n  font-size:clamp(26px,4vw,42px);\n  font-weight:900;\n  margin-bottom:40px;\n  text-align:center;\n  display:flex;\n  align-items:center;\n  justify-content:center;\n  gap:14px;\n  color:#ffffff;\n  transition:.4s ease;\n}\n\nhtml.light-mode .siri-title{\n  color:#111;\n}\n\n.siri-title svg{\n  width:28px;\n  height:28px;\n  fill:#ffffff;\n  transition:.4s ease;\n}\n\nhtml.light-mode .siri-title svg{\n  fill:#111;\n}\n\n/* ===== النص ===== */\n.siri-text{\n  font-size:clamp(17px,2vw,21px);\n  line-height:2.2;\n  margin-bottom:35px;\n  max-width:900px;\n  margin-left:auto;\n  margin-right:auto;\n  text-align:center;\n  color:#cfcfcf;\n  transition:.4s ease;\n}\n\nhtml.light-mode .siri-text{\n  color:#333;\n}\n\n/* ===== صورة Safari ===== */\n.siri-image-wrapper{\n  display:flex;\n  justify-content:center;\n  margin:40px 0;\n}\n\n.siri-image-wrapper img{\n  width:100%;\n  max-width:260px; /* حجم صغير */\n  border-radius:20px;\n  box-shadow:0 20px 60px rgba(0,0,0,0.6);\n  transition:.4s ease;\n}\n\n@media(max-width:480px){\n  .siri-image-wrapper img{\n    max-width:180px; /* أصغر للموبايل الصغير */\n  }\n}\n\n/* ===== المميزات ===== */\n.siri-features{\n  max-width:900px;\n  margin:0 auto 60px auto;\n  display:flex;\n  flex-direction:column;\n  gap:20px;\n}\n\n.siri-feature{\n  background:rgba(255,255,255,0.05);\n  padding:20px;\n  border-radius:18px;\n  font-size:18px;\n  color:#ffffff;\n  transition:.4s ease;\n}\n\nhtml.light-mode .siri-feature{\n  background:#f1f3f7;\n  color:#111;\n}\n\n/* ===== الوسوم ===== */\n.siri-tags{\n  text-align:center;\n  margin-top:50px;\n  font-size:15px;\n  color:#9aa0b5;\n  transition:.4s ease;\n}\n\nhtml.light-mode .siri-tags{\n  color:#555;\n}\n</style>\n\n<!-- زر -->\n<div class=\"siri-theme-toggle\">\n  <button onclick=\"toggleTheme()\" id=\"themeIcon\">🌙</button>\n</div>\n\n<div class=\"siri-card\">\n\n<h1 class=\"siri-title\">\n  <svg viewBox=\"0 0 384 512\">\n    <path d=\"M318.7 268.1c-.3-56.5 46.2-83.6 48.3-84.9-26.4-38.6-67.6-43.9-82.2-44.5-35-3.5-68.4 20.6-86.2 20.6-17.8 0-45.4-20.1-74.6-19.5-38.4.6-73.8 22.4-93.6 57-40 69.4-10.2 172.3 28.8 228.6 19.1 27.6 41.8 58.6 71.7 57.4 28.9-1.2 39.8-18.7 74.7-18.7 34.9 0 44.7 18.7 75.4 18.1 31.2-.6 50.9-28.2 69.9-55.9 21.9-31.9 30.9-62.8 31.2-64.4-.7-.3-59.8-22.9-60.1-90.8z\"/>\n    <path d=\"M259.4 81.5c15.9-19.3 26.6-46.2 23.7-72.9-22.9.9-50.6 15.3-67 34.6-14.7 17-27.6 44.2-24.1 70.2 25.6 2 51.4-13 67.4-31.9z\"/>\n  </svg>\n  سيري تدخل عصرًا جديدًا\n</h1>\n\n<p class=\"siri-text\">\nنسخة Siri المدعومة بنموذج Gemini يُتوقع إطلاقها تجريبيًا الأسبوع القادم، وقد تكون هذه أكبر قفزة حققتها آبل في مجال الذكاء الاصطناعي حتى الآن.\n</p>\n\n<!-- صورة سفاري بالمنتصف -->\n<div class=\"siri-image-wrapper\">\n  <img src=\"https://upload.wikimedia.org/wikipedia/commons/5/52/Safari_browser_logo.svg\" alt=\"Safari Browser\">\n</div>\n\n<p class=\"siri-text\">التحديث الجديد يعد بـ:</p>\n\n<div class=\"siri-features\">\n  <div class=\"siri-feature\">🔹 محادثات أذكى وأكثر سلاسة</div>\n  <div class=\"siri-feature\">🔹 فهم حقيقي للسياق وليس أوامر منفصلة</div>\n  <div class=\"siri-feature\">🔹 مساعد رقمي يبدو أقرب للذكاء الفعلي، لا مجرد أداة صوتية</div>\n</div>\n\n<p class=\"siri-text\">\nمع هذه الخطوة، سباق الذكاء الاصطناعي أصبح أكثر إثارة وتعقيدًا، ودخول آبل بهذا الشكل قد يغيّر موازين الاستخدام اليومي للمساعدات الذكية.\n</p>\n\n<div class=\"siri-tags\">\n#الذكاء_الاصطناعي #Apple #Siri #Gemini #تقنية\n</div>\n\n</div>\n\n<script>\nfunction toggleTheme(){\n  const root = document.documentElement;\n  const btn = document.getElementById('themeIcon');\n\n  root.classList.toggle('light-mode');\n\n  if(root.classList.contains('light-mode')){\n    btn.textContent='☀';\n    localStorage.setItem('theme','light');\n  } else {\n    btn.textContent='🌙';\n    localStorage.setItem('theme','dark');\n  }\n}\n\nwindow.addEventListener('DOMContentLoaded',()=>{\n  const savedTheme = localStorage.getItem('theme');\n  const btn = document.getElementById('themeIcon');\n  if(savedTheme==='light'){\n    document.documentElement.classList.add('light-mode');\n    btn.textContent='☀';\n  }\n});\n</script>\n\n</section>",
