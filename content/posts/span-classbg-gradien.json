er; gap:12px; background:#f1f5f9; color:#0f172a; padding:10px 20px; border-radius:50px; font-weight:800; font-size:1.1rem; margin:30px 0 20px; border:1px solid #e2e8f0; }\n.steps-list { list-style:none; padding:0; counter-reset:step; }\n.steps-list li { position:relative; padding:15px 20px 15px 50px; background:#fff; border:1px solid #e2e8f0; border-radius:12px; margin-bottom:12px; font-weight:600; transition:.3s; }\n.steps-list li::before { content:counter(step); counter-increment:step; position:absolute; right:15px; top:50%; transform:translateY(-50%); width:28px; height:28px; background:#2563eb; color:#fff; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.9rem; font-weight:bold; }\n.steps-list li:hover { transform:translateX(-5px); border-color:#2563eb; box-shadow:0 5px 15px rgba(37,99,235,0.1); }\n/* Downloads */\n.down-grid { display:grid; grid-template-columns:repeat(auto-fit, minmax(280px, 1fr)); gap:15px; margin-top:40px; padding-top:30px; border-top:2px dashed #e2e8f0; }\n.down-btn { display:flex; align-items:center; justify-content:center; gap:12px; padding:16px; border-radius:16px; text-decoration:none; font-weight:800; font-size:1.1rem; color:#fff; transition:.3s; box-shadow:0 10px 20px -5px rgba(0,0,0,0.15); }\n.down-btn:hover { transform:translateY(-3px); filter:brightness(1.1); }\n.down-btn.google { background:linear-gradient(135deg, #00C853, #009624); }\n.down-btn.apple { background:linear-gradient(135deg, #333, #000); }\n.down-btn.tele { background:linear-gradient(135deg, #29B6F6, #0288D1); }\n.down-btn.web { background:linear-gradient(135deg, #6366f1, #4f46e5); }\n.cms-title { text-align:center; font-size:1.8rem; margin-bottom:30px; font-weight:900; line-height:1.4; }\n</style></head><body>\n<div class=\"cms-title\"></div>\n<div class=\"art-container\">\n    <p>شرح خصائص كاب كات</p>\n    <div class=\"my-8\"><div class=\"vid-box normal\"><iframe src=\"https://www.youtube.com/embed/IuJ679a4Sh8\" allowfullscreen